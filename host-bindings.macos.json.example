{
  "schema_version": 1,
  "host": "mac",
  "source_roots": {
    "personal/skill-vault": "/Users/example/personal/sources/skill-vault",
    "work/skill-vault": "/Users/example/work/sources/skill-vault"
  },
  "bindings": {
    "mac.codex.runtime-home": {
      "kind": "path",
      "path": "/Users/example/.codex-runtime"
    },
    "mac.codex.user-home": {
      "kind": "path",
      "path": "/Users/example/.codex"
    },
    "mac.qoder.user-home": {
      "kind": "path",
      "path": "/Users/example/.qoder"
    },
    "mac.qoder.work-home": {
      "kind": "path",
      "path": "/Users/example/.qoderwork"
    }
  }
}
