{
  "schema_version": 1,
  "layer": {
    "residency": "mac-local",
    "host": "mac"
  },
  "sources": {
    "work-source": {
      "repository": "work/skill-vault",
      "revision": {
        "kind": "git-commit",
        "value": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
      },
      "residency": "mac-local-work",
      "authority": "authored-owned",
      "host": "mac"
    }
  },
  "targets": {
    "mac.qoder.work": {
      "host": "mac",
      "consumer": "qodercli",
      "bindings": ["mac.qoder.work-home"]
    }
  },
  "bindings": {
    "mac.qoder.work-home": {
      "host": "mac",
      "kind": "path",
      "role": "qoder.work-home"
    }
  },
  "assets": {
    "skill.work-demo": {
      "kind": "skill",
      "source": {
        "source": "work-source",
        "path": "skills/work-demo"
      },
      "mutation_authority": "almagest-managed"
    }
  },
  "assignments": {
    "skill.work-demo@mac.codex": {
      "asset": "skill.work-demo",
      "target": "mac.codex"
    },
    "skill.demo@mac.qoder.work": {
      "asset": "skill.demo",
      "target": "mac.qoder.work"
    },
    "skill.work-demo@mac.qoder.work": {
      "asset": "skill.work-demo",
      "target": "mac.qoder.work"
    }
  }
}
